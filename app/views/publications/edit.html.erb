<div class="container mt-4">
  <div class="card text-bg-light mb-3 mx-auto" style="max-width: 24rem;">
    <div class="card-header">Editar Publicacion</div>
    <div class="card-body">
      
      <% if @publication.errors.any? %>
        <div class="alert alert-danger">
          <h5>Errores al editar publicacion:</h5>
          <ul>
            <% @publication.errors.full_messages.each do |pbl| %>
              <li><%= pbl %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with(model: @publication, local: true) do |form|  %>
    <div class="mb-3">
          <%= form.label :publication_image, "Editar Imagen" %>
          <%= form.text_field :publication_image, placeholder: "URL de imagen", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= form.label :description, "Editar Descripcion" %>
          <%= form.text_area :description, placeholder: "Agregue descripcion", class: "form-control" %>
        </div>

    <div class="d-flex justify-content-between">
    <%= form.submit "Actualizar", class: "btn btn-primary btn-sm" %> 
    <%= link_to 'Volver', hashtag_path, class: "btn btn-secondary btn-sm" %>
    </div>
    <% end %>

    </div>
  </div>
</div>