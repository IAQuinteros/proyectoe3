<div class="container mt-4">
  <div class="card text-bg-light mb-3 mx-auto" style="max-width: 24rem;">
    <div class="card-header">Editar comentario</div>
    <div class="card-body">
      
      <% if @comment.errors.any? %>
        <div class="alert alert-danger">
          <h5>Errores al crear nuevo comentario:</h5>
          <ul>
            <% @comment.errors.full_messages.each do |cmt| %>
              <li><%= cmt %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with(model: @comment, local: true) do |form| %>
        <div class="mb-3">
        <div>
          <%= form.label :user_id, "Username de usuario: " %>
          <%= form.select :user_id, User.all.map { |u| [u.username, u.id]}, {}, class: "form-select"%>
        </div>

        <div>
          <%= form.label :publication_id, "Id de publicacion: " %>
          <%= form.select :publication_id, Publication.all.map { |p| ["#{p.user.username}-(id: #{p.id})", p.id]}, {}, class: "form-select"%>
        </div>

        <div>
          <strong><%= form.label :content, "Mensaje" %></strong><br>
          <%= form.text_area :content, class: "form-control" %>
        </div>

          <div>
          <%= form.hidden_field :actualization_date, value: Date.today %>
        </div>

        <div class="d-flex justify-content-between">
        <%= link_to 'Volver', comments_path, class: "btn btn-secondary btn-sm" %>
          <%= form.submit "Actualizar", class: "btn btn-primary btn-sm" %> 
        </div>
      <% end %>