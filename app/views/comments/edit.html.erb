<div class="container mt-4">
  <div class="card text-bg-light mb-3 mx-auto" style="max-width: 24rem;">
    <div class="card-header">Editar comentario</div>
    <div class="card-body">
      
      <% if @comment.errors.any? %>
        <div class="alert alert-danger">
          <h5>Errores al actualizar comentario:</h5>
          <ul>
            <% @comment.errors.full_messages.each do |cmt| %>
              <li><%= cmt %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with(model: @comment, local: true) do |form| %>
        <div class="mb-3">
          <div>
            <%= form.label :user_id, "Usuario:" %><br>
            <%= @comment.user.username %>
            <%= form.hidden_field :user_id, value: @comment.user_id %>
          </div>

          <div class="mt-3">
            <%= form.label :publication_id, "Publicación:" %><br>
            <%= "#{@comment.publication.user.username} (id: #{@comment.publication.id})" %>
            <%= form.hidden_field :publication_id, value: @comment.publication_id %>
          </div>

          <div class="mt-3">
            <strong><%= form.label :content, "Mensaje" %></strong><br>
            <%= form.text_area :content, class: "form-control" %>
          </div>

          <div>
            <%= form.hidden_field :actualization_date, value: Date.today %>
          </div>

          <div class="d-flex justify-content-between mt-3">
            <%= link_to 'Volver', comments_path, class: "btn btn-secondary btn-sm" %>
            <%= form.submit "Actualizar", class: "btn btn-primary btn-sm" %> 
          </div>
      <% end %>
    </div>
  </div>
</div>
