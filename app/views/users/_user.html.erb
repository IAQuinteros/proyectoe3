<tr>
  <td><%= index + 1 %></td>
  <td><%= user.name %></td>
  <td><%= user.username %></td>
  <td><%= user.email %></td>
  <td><%= user.sex %></td>
  <td>
    <% if user.user_image.present? %>
      <%= image_tag user.user_image, width: 50, height: 50, class: "rounded-circle" %>
    <% else %>
      Sin imagen
    <% end %>
  </td>
  
  <td>
    <%= link_to 'Ver', user_path(user), class: "btn btn-primary btn-sm" %>
    
    <% if can? :update, user %>
      <%= link_to 'Editar', 
            (current_user.admin? ? edit_user_path(user) : edit_user_registration_path), 
            class: "btn btn-primary btn-sm" %>
    <% end %>
    
    <% if can? :destroy, user %>
      <%= button_to current_user.admin? ? 'Eliminar' : 'Eliminar mi cuenta', 
            current_user.admin? ? user_path(user) : registration_path(user),
            method: :delete,
            data: { confirm: current_user.admin? ? '¿Eliminar este usuario?' : '¿Eliminar tu cuenta permanentemente?' },
            class: "btn btn-danger btn-sm" %>
    <% end %>
  </td>
</tr>