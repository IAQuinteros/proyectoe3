<div class="container mt-4">
  <div class="card text-bg-light mb-3 mx-auto" style="max-width: 24rem;">
    <div class="card-header">Editar Like</div>
    <div class="card-body">
      
      <% if @like.errors.any? %>
        <div class="alert alert-danger">
          <h5>Errores al editar like:</h5>
          <ul>
            <% @like.errors.full_messages.each do |lke| %>
              <li><%= lke %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with(model: @like, local: true) do |form|  %>
    <div class="mb-3">
        <div>
          <%= form.label :user_id, "Username de usuario: " %>
          <%= form.select :user_id, User.all.map { |u| [u.username, u.id] }, {}, class: "form-select" %>
        </div>
        <div>
          <%= form.label :publication_id, "Id de publicacion: " %>
          <%= form.select :publication_id, Publication.all.map { |p| ["#{p.id} - #{p.user.username}", p.id] }, {}, class: "form-select" %>
        </div>
    <div class="d-flex justify-content-between">
    <%= link_to 'Volver', likes_path, class: "btn btn-secondary btn-sm" %>
    <%= form.submit "Actualizar", class: "btn btn-primary btn-sm" %> 
    </div>
    <% end %>

    </div>
  </div>
</div>