<div class="container mt-4">
  <h1>Hashtags</h1>

  <% if can?(:create, Hashtag) %>
    <%= link_to 'Add new hashtag', new_hashtag_path, class: "btn btn-success mb-3" %>
  <% end %>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>Nombre</th>
        <th class="text-end">Acción</th>
      </tr>
    </thead>
    <tbody>
      <% @hashtags.each do |hashtag| %>
        <tr>
          <td><%= hashtag.name %></td>
          <td class="text-end">
            <%= link_to "Ver", hashtag_path(hashtag), class: "btn btn-primary btn-sm" %>

            <% if can?(:edit, hashtag) %>
              <%= link_to "Editar", edit_hashtag_path(hashtag), class: "btn btn-warning btn-sm" %>
            <% end %>

            <% if can?(:destroy, hashtag) %>
              <%= button_to 'Eliminar', hashtag_path(hashtag), method: :delete, data: { confirm: '¿Seguro que desea eliminar este hashtag?' }, class: "btn btn-danger btn-sm" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
