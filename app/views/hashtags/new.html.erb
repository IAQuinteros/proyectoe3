<div class="container mt-4">
  <div class="card text-bg-light mb-3 mx-auto" style="max-width: 24rem;">
    <div class="card-header">Crear Hashtag</div>
    <div class="card-body">
      
      <% if @hashtag.errors.any? %>
        <div class="alert alert-danger">
          <h5>Errores al crear nuevo hashtag:</h5>
          <ul>
            <% @hashtag.errors.full_messages.each do |usr| %>
              <li><%= usr %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with(model: @hashtag, local: true) do |form| %>
        <div class="mb-3">
        <%= form.label :name, 'Nombre' %>
        <%= form.text_field :name, placeholder: "Nombre del Hashtag", class: "form-control" %>
        </div>

        <div class="d-flex justify-content-between">
          <%= form.submit "Guardar", class: "btn btn-primary btn-sm", id: "liveAlertBtn" %>
          <%= link_to 'Volver', hashtags_path, class: "btn btn-secondary btn-sm" %>
        </div>
      <% end %>