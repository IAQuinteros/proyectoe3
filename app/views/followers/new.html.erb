<div class="container mt-4">
  <div class="card text-bg-light mb-3 mx-auto" style="max-width: 24rem;">
    <div class="card-header">Crear Followers</div>
    <div class="card-body">
      
      <% if @follower.errors.any? %>
        <div class="alert alert-danger">
          <h5>Errores al crear nuevo follower:</h5>
          <ul>
            <% @follower.errors.messages.each do |attribute, messages| %>
              <% messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with(model: @follower, local: true) do |form| %>
        <div class="mb-3">
          <%= form.hidden_field :date_followers, value: Date.today %>
          <%= form.hidden_field :user_id, value: current_user.id %>

          <div>
            <%= form.label :followed_user_id, "Seguir a:" %>
            <%= form.select :followed_user_id, User.where.not(id: current_user.id).map { |u| [u.username, u.id] }, {}, class: "form-select" %>
          </div>

          <div class="d-flex justify-content-between mt-3">
            <%= link_to 'Volver', followers_path, class: "btn btn-secondary btn-sm" %>
            <%= form.submit "Guardar", class: "btn btn-primary btn-sm", id: "liveAlertBtn" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
