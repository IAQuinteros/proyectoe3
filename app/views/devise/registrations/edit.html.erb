<div class="container mt-4">
  <div class="card text-bg-light mb-3 mx-auto" style="max-width: 24rem;">
    <div class="card-header">Editar Usuario</div>
    <div class="card-body">
      
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), 
            html: { method: :put, class: "form" }) do |f| %>

        <div class="mb-3">
          <%= f.label :name, "Nombre" %>
          <%= f.text_field :name, class: "form-control", value: resource.name %>
        </div>

        <div class="mb-3">
          <%= f.label :email, "Email" %>
          <%= f.email_field :email, class: "form-control", value: resource.email %>
        </div>

        <div class="mb-3">
          <%= f.label :username, "Username" %>
          <%= f.text_field :username, class: "form-control", value: resource.username %>
        </div>

        <div class="mb-3">
          <%= f.label :user_image, "Imagen (URL)" %>
          <%= f.text_field :user_image, class: "form-control", value: resource.user_image %>
        </div>

                <div class="mb-3">
          <%= f.label :password, "Nueva contraseña" %>
          <small class="text-muted">(dejar en blanco si no quieres cambiarla)</small>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :password_confirmation, "Confirmar nueva contraseña" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :current_password, "Contraseña actual *", class: "form-label" %>
          <small class="text-muted">(necesaria para confirmar cambios)</small>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control", required: true %>
        </div>

        <div class="d-flex justify-content-between">
          <%= link_to 'Volver', :back, class: "btn btn-secondary btn-sm" %>
          <%= f.submit "Actualizar", class: "btn btn-primary btn-sm" %>
        </div>
      <% end %>

    </div>
  </div>
</div>